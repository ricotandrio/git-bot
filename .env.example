# ============================================================
# GitBot — Discord × GitHub Projects Integration
# .env.example — Copy to .env and fill in your values
# ============================================================

NODE_ENV=development

# ────────────────────────────────────────
# DISCORD
# ────────────────────────────────────────

# Bot token from Discord Developer Portal → Your App → Bot → Token
DISCORD_BOT_TOKEN=

# Your Discord Application ID (OAuth2 → General → Application ID)
DISCORD_CLIENT_ID=

# The Guild (Server) ID where the bot is deployed
# Right-click your server icon → Copy Server ID (Developer Mode must be on)
DISCORD_GUILD_ID=

# Channel ID where daily standup posts will be sent
# Right-click the channel → Copy Channel ID
DISCORD_STANDUP_CHANNEL_ID=


# ────────────────────────────────────────
# GITHUB
# ────────────────────────────────────────

# Personal Access Token (classic) with scopes: repo, project
# GitHub → Settings → Developer Settings → Personal Access Tokens → Tokens (classic)
GITHUB_PAT=

# GitHub username or org that owns the target repository
GITHUB_OWNER=

# Target repository name (single repo for MVP)
GITHUB_REPO=

# ────────────────────────────────────────
# Gemini 
# ────────────────────────────────────────

# Gemini API key for AI-powered features (optional)
GEMINI_API_KEY=

# ────────────────────────────────────────
# SERVER
# ────────────────────────────────────────

# Port for the Express server
PORT=3000

# Environment: development | production
NODE_ENV=development


# ────────────────────────────────────────
# STORAGE
# ────────────────────────────────────────

# Storage driver for Discord ↔ GitHub user mapping
# Options: json | sqlite
STORAGE_DRIVER=sqlite

# Path to SQLite database file (used if STORAGE_DRIVER=sqlite)
SQLITE_DB_PATH=./data/gitbot.db